PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/porashona_sohayok

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Groq AI (https://console.groq.com/keys থেকে ফ্রি নিতে পারবেন)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google OAuth (https://console.cloud.google.com থেকে নিতে হবে)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Cloudinary (ছবি আপলোডের জন্য - https://cloudinary.com থেকে ফ্রি অ্যাকাউন্ট খুলে Dashboard থেকে নিতে পারবেন)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Frontend URL (CORS-এর জন্য)
CLIENT_URL=http://localhost:3000

# Demo user credentials (demo login বাটনের জন্য)
DEMO_EMAIL=demo@porashonasohayok.com
DEMO_PASSWORD=Demo@1234
